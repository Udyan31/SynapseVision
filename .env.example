# Copy this file to .env and fill in your key.
#
# Fireworks AI (https://fireworks.ai) is used instead of Gemini for the
# clinical-insight text generation step, because Gemini 2.5 Flash's API
# access is not reliably available to brand-new / unverified Google Cloud
# accounts. Fireworks AI is self-serve, open to new sign-ups, and its API
# is OpenAI-compatible.
#
# 1. Sign up at https://fireworks.ai
# 2. Go to "API Keys" in your dashboard and create a key
# 3. Paste it below
FIREWORKS_API_KEY=fw_your_key_here

# Optional: override the vision-capable model used for the clinical
# insight text. Defaults to accounts/fireworks/models/kimi-k2p5 if unset.
# Browse available vision models at https://fireworks.ai/models
# FIREWORKS_MODEL=accounts/fireworks/models/kimi-k2p5

# Optional: set to "true" to enable Flask debug mode locally.
# NEVER set this to true in any publicly reachable deployment.
FLASK_DEBUG=false
